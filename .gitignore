# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/

# Environment variables
.env
.env.*
!.env.example

# Build output (if using TypeScript or bundlers)
dist/
build/

# Coverage directory (tests)
coverage/

# Optional: TypeScript cache
*.tsbuildinfo

# Optional: ESLint cache
.eslintcache

# Optional: Stylelint cache
.stylelintcache

# OS files
.DS_Store
Thumbs.db

# Editor folders
.vscode/
.idea/

# Temporary files
tmp/
temp/

# Debug files
*.local

# Uploads (if your app stores user files locally)
uploads/
public/uploads/

# Database files (if using SQLite or similar)
*.sqlite
*.sqlite3
*.db

# Cache
.cache/

# Optional: PM2 ecosystem logs
.pm2/

# Optional: dotenv local overrides
.env.local

# Lock files (keep ONE depending on your package manager)
# Uncomment the ones you DON'T use:

# package-lock.json
# yarn.lock
# pnpm-lock.yaml